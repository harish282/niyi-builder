{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/harish282/niyi-builder/schemas/layout-v0.json",
  "title": "Niyi Builder layout document v0",
  "description": "Internal JSON model for the Gutenberg visual builder. Serializes to WordPress core blocks only.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "root"],
  "properties": {
    "version": {
      "const": 0,
      "description": "Schema version; bump when breaking the document shape."
    },
    "root": {
      "$ref": "#/$defs/blockNode",
      "description": "Must be a core/group block."
    }
  },
  "$defs": {
    "blockType": {
      "type": "string",
      "enum": [
        "core/group",
        "core/columns",
        "core/column",
        "core/spacer",
        "core/heading",
        "core/paragraph",
        "core/button",
        "core/image",
        "core/html",
        "core/embed"
      ]
    },
    "blockNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "attributes", "children"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique id within the document."
        },
        "type": { "$ref": "#/$defs/blockType" },
        "attributes": {
          "type": "object",
          "description": "Block-specific settings; see packages/core schema/attributes.ts."
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/blockNode" },
          "description": "Child blocks; must be [] for leaf types."
        }
      }
    }
  }
}
