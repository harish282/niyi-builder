{
  "name": "niyi-builder",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "WordPress visual page builder with native Gutenberg block output",
  "license": "GPL-2.0-or-later",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:packages && npm run build:admin",
    "build:packages": "npm run build --workspaces --if-present",
    "build:admin": "vite build",
    "test": "vitest run",
    "lint": "npm run lint:types && npm run lint:eslint && npm run format:check",
    "lint:types": "tsc -b && tsc --noEmit -p tsconfig.admin.json",
    "lint:eslint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "bash scripts/build-release-zip.sh prod",
    "release:dev": "bash scripts/build-release-zip.sh dev",
    "clean": "npm run clean --workspaces --if-present && rm -f tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@niyi-builder/core": "0.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
