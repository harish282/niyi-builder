{
  "version": 0,
  "root": {
    "id": "root",
    "type": "niyi/container",
    "attributes": {
      "maxWidth": "1200px"
    },
    "children": [
      {
        "id": "hero-section",
        "type": "niyi/container",
        "attributes": {
          "padding": { "desktop": "48px 24px" },
          "background": "#1e293b"
        },
        "children": [
          {
            "id": "hero-grid",
            "type": "niyi/grid",
            "attributes": {
              "columns": { "desktop": 2, "mobile": 1 },
              "gap": { "desktop": "32px" }
            },
            "children": [
              {
                "id": "hero-heading",
                "type": "niyi/heading",
                "attributes": {
                  "level": 1,
                  "content": "Ship faster with Gutenberg"
                },
                "children": []
              },
              {
                "id": "hero-text",
                "type": "niyi/text",
                "attributes": {
                  "content": "Visual editing that saves native blocks."
                },
                "children": []
              },
              {
                "id": "hero-button",
                "type": "niyi/button",
                "attributes": {
                  "label": "Start building",
                  "url": "/builder",
                  "variant": "primary"
                },
                "children": []
              }
            ]
          }
        ]
      },
      {
        "id": "features-grid",
        "type": "niyi/grid",
        "attributes": {
          "columns": { "desktop": 3, "tablet": 2, "mobile": 1 },
          "gap": { "desktop": "24px" }
        },
        "children": [
          {
            "id": "feature-card",
            "type": "niyi/container",
            "attributes": {
              "borderRadius": "12px",
              "padding": { "desktop": "20px" }
            },
            "children": [
              {
                "id": "feature-icon",
                "type": "niyi/icon",
                "attributes": {
                  "name": "layout"
                },
                "children": []
              },
              {
                "id": "feature-title",
                "type": "niyi/heading",
                "attributes": {
                  "level": 3,
                  "content": "Layout blocks"
                },
                "children": []
              },
              {
                "id": "feature-copy",
                "type": "niyi/text",
                "attributes": {
                  "content": "Container, grid, and spacer."
                },
                "children": []
              },
              {
                "id": "feature-image",
                "type": "niyi/image",
                "attributes": {
                  "url": "https://example.com/feature.png",
                  "alt": "Feature"
                },
                "children": []
              },
              {
                "id": "feature-video",
                "type": "niyi/video",
                "attributes": {
                  "provider": "youtube",
                  "url": "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
                },
                "children": []
              }
            ]
          }
        ]
      },
      {
        "id": "section-spacer",
        "type": "niyi/spacer",
        "attributes": {
          "height": { "desktop": "80px" }
        },
        "children": []
      }
    ]
  }
}
