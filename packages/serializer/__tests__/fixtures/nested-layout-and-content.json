{
  "version": 0,
  "root": {
    "id": "root",
    "type": "core/group",
    "attributes": {
      "maxWidth": "1200px"
    },
    "children": [
      {
        "id": "hero-section",
        "type": "core/group",
        "attributes": {
          "padding": { "desktop": "48px 24px" },
          "background": "#1e293b"
        },
        "children": [
          {
            "id": "hero-grid",
            "type": "core/columns",
            "attributes": {
              "columns": { "desktop": 3 },
              "gap": { "desktop": "32px" }
            },
            "children": [
              {
                "id": "hero-col-heading",
                "type": "core/column",
                "attributes": {},
                "children": [
                  {
                    "id": "hero-heading",
                    "type": "core/heading",
                    "attributes": {
                      "level": 1,
                      "content": "Ship faster with Gutenberg"
                    },
                    "children": []
                  }
                ]
              },
              {
                "id": "hero-col-text",
                "type": "core/column",
                "attributes": {},
                "children": [
                  {
                    "id": "hero-text",
                    "type": "core/paragraph",
                    "attributes": {
                      "content": "Visual editing that saves native blocks."
                    },
                    "children": []
                  }
                ]
              },
              {
                "id": "hero-col-button",
                "type": "core/column",
                "attributes": {},
                "children": [
                  {
                    "id": "hero-button",
                    "type": "core/button",
                    "attributes": {
                      "label": "Start building",
                      "url": "/builder"
                    },
                    "children": []
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "features-grid",
        "type": "core/columns",
        "attributes": {
          "columns": { "desktop": 1 },
          "gap": { "desktop": "24px" }
        },
        "children": [
          {
            "id": "feature-column",
            "type": "core/column",
            "attributes": {},
            "children": [
              {
                "id": "feature-card",
                "type": "core/group",
                "attributes": {
                  "borderRadius": "12px",
                  "padding": { "desktop": "20px" }
                },
                "children": [
                  {
                    "id": "feature-icon",
                    "type": "core/html",
                    "attributes": {
                      "name": "layout"
                    },
                    "children": []
                  },
                  {
                    "id": "feature-title",
                    "type": "core/heading",
                    "attributes": {
                      "level": 3,
                      "content": "Layout blocks"
                    },
                    "children": []
                  },
                  {
                    "id": "feature-copy",
                    "type": "core/paragraph",
                    "attributes": {
                      "content": "Group, columns, and spacer."
                    },
                    "children": []
                  },
                  {
                    "id": "feature-image",
                    "type": "core/image",
                    "attributes": {
                      "url": "https://example.com/feature.png",
                      "alt": "Feature"
                    },
                    "children": []
                  },
                  {
                    "id": "feature-video",
                    "type": "core/embed",
                    "attributes": {
                      "provider": "youtube",
                      "url": "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
                    },
                    "children": []
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "section-spacer",
        "type": "core/spacer",
        "attributes": {
          "height": { "desktop": "80px" }
        },
        "children": []
      }
    ]
  }
}
