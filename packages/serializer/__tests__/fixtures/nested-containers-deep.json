{
  "version": 0,
  "root": {
    "id": "root",
    "type": "niyi/container",
    "attributes": {
      "maxWidth": "1440px",
      "padding": { "desktop": "24px" }
    },
    "children": [
      {
        "id": "level-1-container",
        "type": "niyi/container",
        "attributes": {
          "background": "#f5f5f5",
          "borderRadius": "8px"
        },
        "children": [
          {
            "id": "level-2-grid",
            "type": "niyi/grid",
            "attributes": {
              "columns": { "desktop": 2, "tablet": 1 },
              "gap": { "desktop": "24px" }
            },
            "children": [
              {
                "id": "level-3-container",
                "type": "niyi/container",
                "attributes": {
                  "maxWidth": "100%"
                },
                "children": [
                  {
                    "id": "level-4-spacer",
                    "type": "niyi/spacer",
                    "attributes": {
                      "height": { "desktop": "64px", "mobile": "32px" }
                    },
                    "children": []
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
