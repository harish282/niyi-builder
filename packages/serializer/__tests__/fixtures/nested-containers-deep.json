{
  "version": 0,
  "root": {
    "id": "root",
    "type": "core/group",
    "attributes": {
      "maxWidth": "1440px",
      "padding": { "desktop": "24px" }
    },
    "children": [
      {
        "id": "level-1-container",
        "type": "core/group",
        "attributes": {
          "background": "#f5f5f5",
          "borderRadius": "8px"
        },
        "children": [
          {
            "id": "level-2-grid",
            "type": "core/columns",
            "attributes": {
              "columns": { "desktop": 1 },
              "gap": { "desktop": "24px" }
            },
            "children": [
              {
                "id": "level-2-column",
                "type": "core/column",
                "attributes": {},
                "children": [
                  {
                    "id": "level-3-container",
                    "type": "core/group",
                    "attributes": {
                      "maxWidth": "100%"
                    },
                    "children": [
                      {
                        "id": "level-4-spacer",
                        "type": "core/spacer",
                        "attributes": {
                          "height": { "desktop": "64px" }
                        },
                        "children": []
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
